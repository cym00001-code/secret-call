# Copy this file to .env on the server. Never commit real secrets.

# Server
PORT=3101
HOST=0.0.0.0
IP_HASH_SECRET=replace-with-a-long-random-secret
ROOM_TTL_MS=86400000
ROOM_SUSPENDED_TTL_MS=7200000
MESSAGE_TTL_MS=7200000
BURNED_ID_TTL_MS=7200000
CLIENT_TIMEOUT_MS=35000
SECRET_ROOM_DATA_DIR=./data
OFFLINE_SECRET_DB_PATH=./data/offline-secrets.sqlite
MAX_OFFLINE_SECRET_CIPHERTEXT_CHARS=2000000

# Web
NEXT_PUBLIC_WS_URL=ws://localhost:3101/ws
NEXT_PUBLIC_API_BASE_URL=http://localhost:3101
